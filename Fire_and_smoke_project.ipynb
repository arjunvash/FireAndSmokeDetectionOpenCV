        "import os\n",
        "import pandas as pd\n",
        "from PIL import Image\n",
        "\n",
        "\n",
        "dataset_path = '/content/FOREST_FIRE_SMOKE_AND_NON_FIRE_DATASET/test'\n",
        "\n",
        "\n",
        "class_names = []\n",
        "num_images_list = []\n",
        "image_sizes = []\n",
        "image_modes = []\n",
        "\n",
        "\n",
        "for class_name in os.listdir(dataset_path):\n",
        "    class_folder = os.path.join(dataset_path, class_name)\n",
        "    if os.path.isdir(class_folder):\n",
        "        class_names.append(class_name)\n",
        "        num_images = len(os.listdir(class_folder))\n",
        "        num_images_list.append(num_images)\n",
        "\n",
        "        sample_image_path = os.path.join(class_folder, os.listdir(class_folder)[0])\n",
        "        with Image.open(sample_image_path) as img:\n",
        "            image_sizes.append(img.size)\n",
        "            image_modes.append(img.mode)\n",
        "\n",
        "df = pd.DataFrame({\n",
        "    'Class Name': class_names,\n",
        "    'Number of Images': num_images_list,\n",
        "    'Sample Image Size': image_sizes,\n",
        "    'Sample Image Mode': image_modes\n",
        "})\n",
        "\n",
        "\n",
        "print(df)\n"
      ],
